{"noir_version":"1.0.0-beta.19+74d6be658e1ad252f87943292ba09bdd4da80bd4","hash":"7188251631671991284","abi":{"parameters":[{"name":"weights_bps","type":{"kind":"array","length":8,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"coupon_rates_bps","type":{"kind":"array","length":8,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"rating_indices","type":{"kind":"array","length":8,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"amounts","type":{"kind":"array","length":8,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"constraint_min_rating_index","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"constraint_max_rating_index","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"constraint_max_single_exposure_bps","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"constraint_min_bonds","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"constraint_target_yield_bps","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"actual_weighted_coupon_bps","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"actual_num_bonds","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"}],"return_type":null,"error_types":{"361444214588792908":{"error_kind":"string","string":"attempt to multiply with overflow"},"1386462955885416764":{"error_kind":"string","string":"Inactive slot coupon"},"3603099832762122181":{"error_kind":"string","string":"Below minimum bonds required"},"4345481982568013455":{"error_kind":"string","string":"Single exposure exceeds investor limit"},"6747178373105186814":{"error_kind":"string","string":"Coupon too low"},"6985101024972645814":{"error_kind":"string","string":"Inactive slot weight"},"8059528270908996872":{"error_kind":"string","string":"Coupon too high"},"9092859576309782639":{"error_kind":"string","string":"Bond better than investor max rating"},"9332055685649697698":{"error_kind":"string","string":"Inactive slot rating"},"10580955252825801499":{"error_kind":"string","string":"Bond worse than investor min rating"},"12081403810606729596":{"error_kind":"string","string":"Bond count mismatch"},"14875145226156653580":{"error_kind":"string","string":"Weights must sum to 10000"},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"},"17872033519413515272":{"error_kind":"string","string":"Portfolio yield below investor target"}}},"bytecode":"","debug_symbols":"","file_map":{"51":{"source":"// Constraint Compliance Proof\n// ===========================\n// Proves the AI portfolio agent respected the investor's constraints\n// when constructing the portfolio. The investor specified parameters\n// (min rating, max exposure, min bonds, target yield) and this proof\n// verifies the private allocations satisfy all of them.\n\nfn main(\n    // Private: actual portfolio allocations\n    weights_bps: [u64; 8],\n    coupon_rates_bps: [u64; 8],\n    rating_indices: [u8; 8],\n    amounts: [u64; 8],\n\n    // Public: investor's original constraints\n    constraint_min_rating_index: pub u8,    // worst acceptable (higher = worse)\n    constraint_max_rating_index: pub u8,    // best acceptable (lower = better)\n    constraint_max_single_exposure_bps: pub u64,\n    constraint_min_bonds: pub u8,\n    constraint_target_yield_bps: pub u64,\n\n    // Public: what the portfolio actually achieved\n    actual_weighted_coupon_bps: pub u64,\n    actual_num_bonds: pub u8,\n) {\n    // --- 1. Count active bonds ---\n    let mut num_bonds: u8 = 0;\n    let mut total_weight: u64 = 0;\n    for i in 0..8 {\n        if amounts[i] > 0 {\n            num_bonds += 1;\n        }\n        total_weight += weights_bps[i];\n    }\n    assert(num_bonds == actual_num_bonds, \"Bond count mismatch\");\n\n    // --- 2. Weights sum to 100% ---\n    assert(total_weight == 10000, \"Weights must sum to 10000\");\n\n    // --- 3. Min bonds constraint ---\n    assert(num_bonds >= constraint_min_bonds, \"Below minimum bonds required\");\n\n    // --- 4. All ratings within investor's acceptable range ---\n    for i in 0..8 {\n        if amounts[i] > 0 {\n            assert(\n                rating_indices[i] >= constraint_max_rating_index,\n                \"Bond better than investor max rating\",\n            );\n            assert(\n                rating_indices[i] <= constraint_min_rating_index,\n                \"Bond worse than investor min rating\",\n            );\n        }\n    }\n\n    // --- 5. No single bond exceeds max exposure ---\n    for i in 0..8 {\n        assert(\n            weights_bps[i] <= constraint_max_single_exposure_bps,\n            \"Single exposure exceeds investor limit\",\n        );\n    }\n\n    // --- 6. Weighted coupon meets target yield ---\n    let mut weighted_coupon_sum: u64 = 0;\n    for i in 0..8 {\n        weighted_coupon_sum += weights_bps[i] * coupon_rates_bps[i];\n    }\n    // Verify actual_weighted_coupon_bps is floor(sum / 10000)\n    assert(\n        actual_weighted_coupon_bps * 10000 <= weighted_coupon_sum,\n        \"Coupon too high\",\n    );\n    assert(\n        (actual_weighted_coupon_bps + 1) * 10000 > weighted_coupon_sum,\n        \"Coupon too low\",\n    );\n    // Achieved yield must meet or exceed target\n    assert(\n        actual_weighted_coupon_bps >= constraint_target_yield_bps,\n        \"Portfolio yield below investor target\",\n    );\n\n    // --- 7. Zero slots clean ---\n    for i in 0..8 {\n        if amounts[i] == 0 {\n            assert(weights_bps[i] == 0, \"Inactive slot weight\");\n            assert(coupon_rates_bps[i] == 0, \"Inactive slot coupon\");\n            assert(rating_indices[i] == 0, \"Inactive slot rating\");\n        }\n    }\n}\n","path":"/Users/narasimhatejareddy/Desktop/Hackzz/rayls/circuits/constraint_proof/src/main.nr"}}}