# Public chain
PUBLIC_CHAIN_RPC_URL=https://testnet-rpc.rayls.com

# Contracts
TOKEN_ADDRESS=0x
ATTESTATION_ADDRESS=0x

# Agent wallet (needs gas on public chain)
AGENT_PRIVATE_KEY=0x

# AI provider: "gemini" (free tier), "anthropic", "openai", or "openrouter"
AI_PROVIDER=gemini

# Google Gemini (free) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (Claude) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — get key at https://platform.openai.com
OPENAI_API_KEY=

# OpenRouter — get key at https://openrouter.ai/keys (access 300+ models)
OPENROUTER_API_KEY=
# Set a specific model, or "auto" to try all free models in order until one works:
# OPENROUTER_MODEL=auto
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=deepseek/deepseek-r1:free
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MODEL=auto
